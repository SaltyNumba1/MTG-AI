{
  "name": "mtg-collection-frontend",
  "version": "1.0.0",
  "description": "MTG Collection desktop app wrapper",
  "author": "",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:dev": "concurrently \"cd ..\\backend && .venv\\Scripts\\python.exe -m uvicorn main:app --reload\" \"npm:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:build": "cd ..\\backend && call .\\package_standalone.bat && cd ..\\frontend && if exist release rmdir /s /q release && electron-builder",
    "desktop:package": "npm run build && electron-packager . \"MTG Collection\" --platform=win32 --arch=x64 --icon=build/icon.ico --out release --overwrite --prune=true && mkdir \"release\\MTG Collection-win32-x64\\resources\\backend\\dist\" 2>nul && copy \"..\\backend\\dist\\mtg-collection.exe\" \"release\\MTG Collection-win32-x64\\resources\\backend\\dist\\\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.2",
    "typescript": "^5.4.5",
    "vite": "^5.4.21",
    "wait-on": "^7.0.1",
    "concurrently": "^8.2.1"
  },
  "build": {
    "appId": "com.mtg.collection",
    "productName": "MTG Collection",
    "forceCodeSigning": false,
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis"]
    },
    "files": [
      "dist/**/*",
      "electron-main.js"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  }
}
